<UserControl
	x:Class				="CoPilotStatusExtension.Views.StatusInfoPopupControl"
	xmlns				="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x				="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:sys			="clr-namespace:System;assembly=mscorlib"
	xmlns:vsshell		="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
	xmlns:platformUI	="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
	xmlns:localVM		="clr-namespace:CoPilotStatusExtension.ViewModels"

	xmlns:mc			="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d				="http://schemas.microsoft.com/expression/blend/2008"
	mc:Ignorable		="d"
	d:DataContext		="{d:DesignInstance Type=localVM:GitHubStatusBarViewModel}"
	d:Background		="LightGray"

	Foreground			="{DynamicResource {x:Static vsshell:VsBrushes.PanelTextKey}}"
	>

	<!-- ==== Resources =============================================================================================================== -->
	<UserControl.Resources>
		<ResourceDictionary>

			<!-- ==== Merged Dictionaries ========================================================================= -->
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="pack://application:,,,/CoPilotStatusExtension;component/Views/Resources/StaticResources.xaml" />
				<ResourceDictionary Source="pack://application:,,,/CoPilotStatusExtension;component/Views/Resources/ConverterResources.xaml" />
				<ResourceDictionary Source="pack://application:,,,/CoPilotStatusExtension;component/Views/Resources/StyleResources.xaml" />
				<ResourceDictionary Source="pack://application:,,,/CoPilotStatusExtension;component/Views/Resources/DefaultMargins.xaml" />
			</ResourceDictionary.MergedDictionaries>

			<!-- ==== New Resources =============================================================================== -->
			<sys:Double x:Key="BackgroundProgressOpacity">0.5</sys:Double>

			<!-- ================================================================================================== -->
			<Style TargetType="Expander" BasedOn="{StaticResource {x:Type Expander}}">
				<Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarTextActiveKey}}" />
			</Style>

			<Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
				<Setter Property="IsHitTestVisible"		Value="False" />
				<Setter Property="Focusable"			Value="False" />
				<Setter Property="HorizontalAlignment"	Value="Center" />
				<Setter Property="VerticalAlignment"	Value="Center" />
			</Style>

			<!-- information group border style -->
			<Style
				x:Key		="InformationGroupBorderStyle"
				TargetType	="Border"
				>

				<Setter Property="Background"		Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"/>
				<Setter Property="d:BorderBrush"	Value="magenta"/>
				<!--<Setter Property="BorderBrush"		Value="{DynamicResource {x:Static platformUI:EnvironmentColors.SystemInactiveBorderBrushKey}}"/>-->
				<Setter Property="BorderThickness"	Value="1"/>

				<Setter Property="CornerRadius"		Value="15"/>
				<Setter Property="Margin"			Value="{StaticResource SmallMarginTL}"/>
				<Setter Property="Padding"			Value="{StaticResource SmallMarginBR}"/>

				<!--<Setter Property="Effect">
					<Setter.Value>
						<DropShadowEffect
							BlurRadius	="8"
							Color		="{DynamicResource {x:Static platformUI:EnvironmentColors.SystemThreeDDarkShadowColorKey}}"
							Direction	="-90"
							Opacity		="0.4"
							ShadowDepth	="3"
							/>
					</Setter.Value>
				</Setter>-->

				<Style.Triggers>
					<Trigger Property="IsMouseOver" Value="True">

						<!--<Setter Property="BorderBrush"	Value="{DynamicResource {x:Static vsshell:VsBrushes.HighlightKey}}"/>-->
						<!--<Setter Property="Background"	Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarHoverOverSelectedKey}}"/>-->
						<Setter Property="Background"	Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabMouseOverBackgroundBeginKey}}"/>
						<!--<Setter Property="Background"	Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarOptionsMouseOverBackgroundBeginKey}}"/>-->

						<!--<Setter Property="Effect">
							<Setter.Value>
								<DropShadowEffect
									BlurRadius	="12"
									Color		="{DynamicResource {x:Static platformUI:EnvironmentColors.SystemHighlightColorKey}}"
									Direction	="-90"
									Opacity		="0.3"
									ShadowDepth	="5"
									/>
							</Setter.Value>
						</Setter>-->
					</Trigger>
				</Style.Triggers>

			</Style>

		</ResourceDictionary>
	</UserControl.Resources>

	<!-- ==== Content ================================================================================================================= -->
	<Border
		Background		="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMenuBackgroundGradientKey}}"
		BorderBrush		="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMenuBorderKey}}"
		BorderThickness	="1"
		MinWidth		="300"
		>
		<platformUI:GroupStackPanel
			Margin ="{StaticResource SmallMarginBR}"
			>

			<!-- ==== Header Lookalike ============================================================================ -->
			<!--Background		="{DynamicResource MouseOverBackground}"-->
			<DockPanel
				Margin	="{StaticResource SmallMarginTL}"
				>

				<Grid
					Margin	="{StaticResource SmallMarginT}"
					DockPanel.Dock	="Bottom"
					>
					<Separator
						VerticalAlignment	="Center"
						HorizontalAlignment	="Stretch"
						Height				="1"
						BorderBrush			="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarTextActiveKey}}"
						d:BorderBrush		="black"
						BorderThickness		="0.5"
						/>
					<ProgressBar
						x:Name="Test"
						Style				="{StaticResource UsageProgressBarStyle}"
						Background			="Transparent"
						BorderBrush			="Transparent"
						Foreground			="{DynamicResource {x:Static platformUI:EnvironmentColors.MainWindowActiveIconDefaultBrushKey}}"
						Value				="{Binding PremiumInteractionsUsedPercent, Mode=OneWay}"
						d:Value				="{StaticResource PreviewProgress}"
						/>
				</Grid>

				<!--Background		="{DynamicResource MouseOverBackground}"-->
				<!--BorderBrush		="{DynamicResource {x:Static vsshell:VsBrushes.SearchBoxBorderKey}}"-->

				<!--Background		="{Binding PremiumInteractionsUsedPercent, Mode=OneWay, Converter={StaticResource ProgressSegmentBrush}, ConverterParameter={StaticResource BackgroundProgressOpacity}}"-->
				<platformUI:HyperlinkButton
					DockPanel.Dock		="Left"
					Margin				="{StaticResource TinyMarginTLBR}"
					Content				="{Binding PersonalInfo.Login, StringFormat='{}{0}🔗'}"
					d:Content			="3rikF"
					Tag					="{Binding UserProfileUrl}"
					Click				="OnUserProfileClick"
					FontSize			="14"
					FontWeight			="Bold"
					/>

				<TextBlock
					DockPanel.Dock		="Right"
					Margin				="{StaticResource TinyMarginTLBR}"
					HorizontalAlignment	="Right"
					FontSize			="14"
					FontWeight			="Bold"
					Foreground			="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarTextActiveKey}}"
					Text				="{Binding PremiumInteractionsUsedPercent, Mode=OneWay, StringFormat='{}{0:P1}'}"
					d:Text				="42%"
					/>

			</DockPanel>

			<!-- ================================================================================================== -->
			<StackPanel
				Margin		="{StaticResource SmallMarginTL}"
				Orientation	="Horizontal"
				>

				<!-- ==== Line 17 ==== -->
				<TextBlock Text="Limits will be reset on "/>
				<TextBlock Text="{Binding PersonalInfo.QuotaResetDateUtc, Converter={StaticResource UtcToLocal}, StringFormat=g}"/>
			</StackPanel>

			<!-- ================================================================================================== -->
			<Border
				Style			="{StaticResource InformationGroupBorderStyle}"
				>
				<Expander
					Margin		="{StaticResource SmallMarginTL}"
					Header		="Extended Information"
					IsExpanded	="False"
					Foreground	="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarTextActiveKey}}"
					>

					<Grid
						Margin	="{StaticResource SmallMarginTL}"
						>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="auto"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Grid.RowDefinitions>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
						</Grid.RowDefinitions>

						<!-- ==== Line 1 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="0"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="🧑🏻‍💼 Copilot Plan:"/>
						<TextBlock
							Grid.Column	="1"
							Grid.Row	="0"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="{Binding PersonalInfo.CopilotPlan, Converter={StaticResource CopilotPlanToText}}"
							HorizontalAlignment="Right"/>

						<!-- ==== Line 2 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="1"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="📦 Access Type SKU:"/>
						<TextBlock
							Grid.Column	="1"
							Grid.Row	="1"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="{Binding PersonalInfo.AccessTypeSku, Converter={StaticResource SubscriptionToText}}"
							HorizontalAlignment="Right"/>

						<!-- ==== Line 3 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="2"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="📆 Assigned Date:"/>
						<TextBlock
							Grid.Column	="1"
							Grid.Row	="2"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="{Binding PersonalInfo.AssignedDate, Converter={StaticResource UtcToLocal}, StringFormat=g}"
							HorizontalAlignment="Right"/>

						<!-- ==== Line 4 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="3"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="🚫 Restricted Telemetry:"/>
						<TextBlock
							Grid.Column	="1"
							Grid.Row	="3"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="{Binding PersonalInfo.RestrictedTelemetry, Converter={StaticResource BoolToText},ConverterParameter='restricted;unrestricted'}"
							HorizontalAlignment="Right"/>

					</Grid>
				</Expander>
			</Border>

			<!-- ================================================================================================== -->
			<Border
				Style			="{StaticResource InformationGroupBorderStyle}"
				>

				<Expander
					Margin		="{StaticResource SmallMarginTL}"
					Header		="CoPilot Features"
					IsExpanded	="False"
					>

					<Grid
						Margin	="{StaticResource SmallMarginTL}"
						>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="auto"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Grid.RowDefinitions>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
							<RowDefinition Height="auto"/>
						</Grid.RowDefinitions>

						<!-- ==== Line 1 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="0"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="💬 Chat"/>
						<CheckBox
							Grid.Column	="1"
							Grid.Row	="0"
							Margin		="{StaticResource NormalLowMarginTL}"
							IsChecked	="{Binding PersonalInfo.ChatEnabled}" />

						<!-- ==== Line 2 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="1"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="🗔 CLI"/>
						<CheckBox
							Grid.Column	="1"
							Grid.Row	="1"
							Margin		="{StaticResource NormalLowMarginTL}"
							IsChecked	="{Binding PersonalInfo.CliEnabled}" />

						<!-- ==== Line 7 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="2"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="📡 CLI Remote Control"/>
						<CheckBox
							Grid.Column	="1"
							Grid.Row	="2"
							Margin		="{StaticResource NormalLowMarginTL}"
							IsChecked	="{Binding PersonalInfo.CliRemoteControlEnabled}" />

						<!-- ==== Line 3 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="3"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="🔌 MCP"/>
						<CheckBox
							Grid.Column	="1"
							Grid.Row	="3"
							Margin		="{StaticResource NormalLowMarginTL}"
							IsChecked	="{Binding PersonalInfo.IsMcpEnabled}"
							/>

						<!-- ==== Line 5 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="4"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="🔬 Preview Features"/>
						<CheckBox
							Grid.Column	="1"
							Grid.Row	="4"
							Margin		="{StaticResource NormalLowMarginTL}"
							IsChecked	="{Binding PersonalInfo.EditorPreviewFeaturesEnabled}" />

						<!-- ==== Line 4==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="5"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="🙈 Copilot Ignore"/>
						<CheckBox
							Grid.Column	="1"
							Grid.Row	="5"
							Margin		="{StaticResource NormalLowMarginTL}"
							IsChecked	="{Binding PersonalInfo.CopilotIgnoreEnabled}" />

						<!-- ==== Line 6 ==== -->
						<TextBlock
							Grid.Column	="0"
							Grid.Row	="6"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="☁️ Cloud Session Storage"/>
						<CheckBox
							Grid.Column	="1"
							Grid.Row	="6"
							Margin		="{StaticResource NormalLowMarginTL}"
							IsChecked	="{Binding PersonalInfo.CloudSessionStorageEnabled}" />



						<!-- ==== Line 8 ==== -->
						<!--
						<TextBlock Text="Login:"/>
						<TextBlock Text="{Binding PersonalInfo.Login}"/>
						-->

						<!-- ==== Line 9 ==== -->
						<!--
						<TextBlock Text="Analytics Tracking ID:"/>
						<TextBlock Text="{Binding PersonalInfo.AnalyticsTrackingId}"/>
						-->

						<!-- ==== Line 10 ==== -->
						<!--<TextBlock
							Grid.Column	="0"
							Grid.Row	="9"
							Margin		="{StaticResource NormalLowMarginTL}"
							Text		="Can Sign-up For Limited:"/>
						<CheckBox
							Grid.Column	="1"
							Grid.Row	="9"
							Margin		="{StaticResource NormalLowMarginTL}"
							IsChecked	="{Binding PersonalInfo.CanSignupForLimited}"/>-->
					</Grid>
				</Expander>
			</Border>

			<!-- ================================================================================================== -->
			<!--<Separator
				Margin				="{StaticResource SmallMarginTL}"
				VerticalAlignment	="Center"
				HorizontalAlignment	="Stretch"
				Height				="1"
				BorderBrush			="{DynamicResource {x:Static vsshell:VsBrushes.PanelSubGroupSeparatorKey}}"
				BorderThickness		="0.5"
				d:BorderBrush		="black"
				/>-->

			<!-- ==== Quote List ================================================================================== -->
			<Border
				Style ="{StaticResource InformationGroupBorderStyle}"
				>

				<ItemsControl
					Margin			="{StaticResource NormalMarginTL}"
					ItemsSource		="{Binding QuotaDetails}"
					d:ItemsSource	="{d:SampleData ItemCount=3}"

					Background				="Transparent"
					BorderBrush				="Transparent"
					BorderThickness			="0"
					>

					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Grid
								Margin="{StaticResource TinyMarginBR}">

								<UniformGrid
									Columns			="2"
									Visibility		="{Binding Unlimited, Converter={StaticResource BoolToVisibility}}"
									d:Visibility	="Collapsed"
									>

									<TextBlock
										Margin		="{StaticResource TinyMarginTL}"
										FontWeight	="Bold"
										Text		="{Binding QuotaId, StringFormat='{}{0}:'}"
										/>


									<TextBlock
										Margin				="{StaticResource TinyMarginTL}"
										Text				="♾️ Unlimited"
										HorizontalAlignment	="Right"
										/>

								</UniformGrid>

								<Grid
									Visibility		="{Binding Unlimited, Converter={StaticResource BoolToVisibility}, ConverterParameter=!}"
									d:Visibility	="Visible"
									>

									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="1*"/>
										<ColumnDefinition Width="2*" />
									</Grid.ColumnDefinitions>

									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<!-- ==== Line 1 ==== -->
									<TextBlock
										Grid.Row	="0"
										Grid.Column	="0"
										Grid.ColumnSpan	="2"
										Margin		="{StaticResource TinyMarginTL}"
										FontWeight	="Bold"
										Text		="{Binding QuotaId, StringFormat='{}{0}:'}"
										d:Text		="Quota Category"
										/>

									<!-- ==== Line 2 ==== -->
									<TextBlock
										Grid.Row	="1"
										Grid.Column	="0"
										Margin		="{StaticResource NormalLowMarginTL}"
										Text		="💰 AI-Credits:"
										/>

									<StackPanel
										Grid.Row	="1"
										Grid.Column	="1"
										Orientation	="Horizontal"
										Margin		="{StaticResource TinyMarginTL}"
										>
										<TextBlock Text ="{Binding Remaining}" />
										<TextBlock Text =" of " />
										<TextBlock Text ="{Binding Entitlement}" />
										<TextBlock Text =" used" />
									</StackPanel>

									<!-- ==== Line 3 ==== -->
									<TextBlock
										Grid.Row	="2"
										Grid.Column	="0"
										Margin		="{StaticResource NormalLowMarginTL}"
										Text		="⚠️ Overage:"
										/>

									<TextBlock
										Grid.Row	="2"
										Grid.Column	="1"
										Visibility	="{Binding OveragePermitted, Converter={StaticResource BoolToVisibility}, ConverterParameter=!}"
										Margin		="{StaticResource TinyMarginTL}"
										Text		="[Not Permitted]"
										/>

									<TextBlock
										Grid.Row	="2"
										Grid.Column	="1"
										Visibility	="{Binding OveragePermitted, Converter={StaticResource BoolToVisibility}}"
										Margin		="{StaticResource TinyMarginTL}"
										Text		="{Binding OverageCount, StringFormat='{}{0} extra AIC used'}"
										/>

									<!-- ==== Line 4 ==== -->
									<!--<TextBlock
										Grid.Row	="3"
										Grid.Column	="0"
										Margin		="{StaticResource TinyMarginTL}"
										Text		="Reset At:"
										/>

									<TextBlock
										Grid.Row	="3"
										Grid.Column	="1"
										Margin		="{StaticResource TinyMarginTL}"
										Text		="{Binding TimestampUtc, Converter={StaticResource UtcToLocal}, StringFormat='{}{0:g}'}"
										/>-->

								</Grid>
							</Grid>
						</DataTemplate>

					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</Border>

		</platformUI:GroupStackPanel>
	</Border>
</UserControl>