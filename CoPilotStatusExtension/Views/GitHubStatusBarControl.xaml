<UserControl
	x:Class				="CoPilotStatusExtension.Views.GitHubStatusBarControl"
	xmlns				="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x				="http://schemas.microsoft.com/winfx/2006/xaml"

	xmlns:sys			="clr-namespace:System;assembly=netstandard"
	xmlns:vsshell		="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
	xmlns:platformUI	="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
	xmlns:localVM		="clr-namespace:CoPilotStatusExtension.ViewModels"

	xmlns:mc			="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d				="http://schemas.microsoft.com/expression/blend/2008"
	mc:Ignorable		="d"

	d:DesignHeight		="25"
	d:DesignWidth		="166"
	d:Background		="Gray"
	d:Foreground		="white"
	d:DataContext		="{d:DesignInstance Type=localVM:GitHubStatusBarViewModel}"
	MouseLeftButtonUp ="ctrlBarItem_MouseLeftButtonUp"
	>

	<!-- ==== Resources =============================================================================================================== -->
	<UserControl.Resources>
		<ResourceDictionary>

			<!-- ==== Merged Dictionaries ========================================================================= -->
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="pack://application:,,,/CoPilotStatusExtension;component/Views/Resources/StaticResources.xaml" />
				<ResourceDictionary Source="pack://application:,,,/CoPilotStatusExtension;component/Views/Resources/ConverterResources.xaml" />
				<ResourceDictionary Source="pack://application:,,,/CoPilotStatusExtension;component/Views/Resources/StyleResources.xaml" />
			</ResourceDictionary.MergedDictionaries>

			<!-- ==== New Resources =============================================================================== -->
		</ResourceDictionary>
	</UserControl.Resources>


	<!-- ==== Style =================================================================================================================== -->
	<UserControl.Style>
		<StaticResource ResourceKey="StatusBarControlStyle" />
	</UserControl.Style>

	<!-- ==== Content ================================================================================================================= -->
	<Grid >

		<!-- ==== Pop-Up ========================================================================================== -->
		<Popup
			x:Name				="ctrlStatusPopup"
			PlacementTarget		="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
			Placement			="Top"
			VerticalOffset		="-4"

			StaysOpen			="False"
			AllowsTransparency	="True"
			d:PopupAnimation	="Fade"
			>

			<local:StatusInfoPopupControl
				xmlns:local="clr-namespace:CoPilotStatusExtension.Views"
				DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
				/>
		</Popup>

		<!-- ==== Bar Item ======================================================================================== -->
		<DockPanel
			x:Name				="ctrlBarItem"
			>


			<ProgressBar
				DockPanel.Dock="Bottom"
				Style			="{StaticResource UsageProgressBarStyle}"
				Visibility		="{Binding PremiumInteractionsUsedPercent, Converter={StaticResource NullToVisibility}}"
				Margin			="0"
				Padding			="0"
				Height			="3"

				Value			="{Binding PremiumInteractionsUsedPercent, Mode=OneWay}"

				d:Visibility	="Visible"
				d:Background	="#FFA0A0A0"
				d:Foreground	="LightGray"
				d:Value			="{StaticResource PreviewProgress}"
				/>

			<StackPanel
				Orientation	 ="Horizontal">

				<Viewbox
					Margin	="8, 0, 0, 0"
					Width	="16"
					Height	="16"
					>
					<Canvas
						Width	="24"
						Height	="24"
						>

						<!-- Old icon, requires 24 x 24-->
