								</Path.RenderTransform>
							</Path>
							<Path
								Fill		="{DynamicResource {x:Static vsshell:VsBrushes.StatusBarTextKey}}"
								d:Fill		="white"
								Data		="M6.25 9.037a.75.75 0 0 1 .75.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 .75-.75Zm4.25.75v1.501a.75.75 0 0 1-1.5 0V9.787a.75.75 0 0 1 1.5 0Z"
								>
								<Path.RenderTransform>
									<ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
								</Path.RenderTransform>
							</Path>

					</Canvas>
				</Viewbox>

				<TextBlock
					VerticalAlignment	="Center"
					Text				="{Binding StatusText}"
					d:Text				="3rikF: 42%"
					Margin				="8, 0, 8, 0"
					>

					<TextBlock.ToolTip>
						<StackPanel>
							<TextBlock
								Text		="{Binding StatusToolTip}"
								FontWeight	="Bold"
								/>

							<StackPanel
								Visibility	="{Binding ApiRateLimitInfo, Converter={StaticResource NullToVisibility}}"
								Orientation	="Horizontal"
								>

								<TextBlock
									Text ="API Limit: "/>

								<TextBlock
									Text ="{Binding ApiRateLimitInfo.Used, Mode=OneWay}"/>

								<TextBlock
									Text =" / "/>

								<TextBlock
									Text ="{Binding ApiRateLimitInfo.Limit, Mode=OneWay}"/>

								<TextBlock
									Text =" used, ↩ "/>

								<TextBlock
									Text ="{Binding ApiRateLimitInfo.Reset, Converter={StaticResource UtcToLocal}, Mode=OneWay, StringFormat=t}"/>

							</StackPanel>
						</StackPanel>
					</TextBlock.ToolTip>

				</TextBlock>

			</StackPanel>
		</DockPanel>
	</Grid>
</UserControl>
