<ResourceDictionary
	xmlns		="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x		="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:ice	="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
	xmlns:sys	="clr-namespace:System;assembly=netstandard"
	>

	<!-- === Skalars ============================================================================================== -->
	<sys:Double x:Key="MarginNormal"	ice:Freeze="true">10</sys:Double>
	<sys:Double x:Key="MarginSmall"		ice:Freeze="true">7</sys:Double>
	<sys:Double x:Key="MarginTiny"		ice:Freeze="true">3</sys:Double>

	<!-- === Normal =============================================================================================== -->
	<!--#region Normal Margins -->

	<Thickness
		x:Key		="NormalMarginTLBR"
		ice:Freeze	="true"
		Left		="{StaticResource MarginNormal}"
		Top			="{StaticResource MarginNormal}"
		Right		="{StaticResource MarginNormal}"
		Bottom		="{StaticResource MarginNormal}" />

	<Thickness
		x:Key		="NormalMarginTLR"
		ice:Freeze	="true"
		Left		="{StaticResource MarginNormal}"
		Top			="{StaticResource MarginNormal}"
		Right		="{StaticResource MarginNormal}"
		Bottom		="0" />

	<Thickness
		x:Key		="NormalMarginTLB"
		ice:Freeze	="true"
		Left		="{StaticResource MarginNormal}"
		Top			="{StaticResource MarginNormal}"
		Right		="0"
		Bottom		="{StaticResource MarginNormal}" />

	<Thickness
		x:Key		="NormalMarginT"
		ice:Freeze	="true"
		Left		="0"
		Top			="{StaticResource MarginNormal}"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="NormalMarginL"
		ice:Freeze	="true"
		Left		="{StaticResource MarginNormal}"
		Top			="0"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="NormalMarginB"
		ice:Freeze	="true"
		Left		="0"
		Top			="0"
		Right		="0"
		Bottom		="{StaticResource MarginNormal}" />

	<Thickness
		x:Key		="NormalMarginR"
		ice:Freeze	="true"
		Left		="0"
		Top			="0"
		Right		="{StaticResource MarginNormal}"
		Bottom		="0" />


	<Thickness
		x:Key		="NormalMarginTL"
		ice:Freeze	="true"
		Left		="{StaticResource MarginNormal}"
		Top			="{StaticResource MarginNormal}"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="NormalLowMarginTL"
		ice:Freeze	="true"
		Left		="{StaticResource MarginNormal}"
		Top			="{StaticResource MarginTiny}"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="NormalMarginBR"
		ice:Freeze	="true"
		Left		="0"
		Top			="0"
		Right		="{StaticResource MarginNormal}"
		Bottom		="{StaticResource MarginNormal}" />

	<Thickness
		x:Key		="NormalMarginBL"
		ice:Freeze	="true"
		Left		="{StaticResource MarginNormal}"
		Top			="0"
		Right		="0"
		Bottom		="{StaticResource MarginNormal}" />

	<Thickness
		x:Key		="NormalMarginLBR"
		ice:Freeze	="true"
		Left		="{StaticResource MarginNormal}"
		Top			="0"
		Right		="{StaticResource MarginNormal}"
		Bottom		="{StaticResource MarginNormal}" />

	<!--#endregion Normal Margins -->

	<!-- === Lesser =============================================================================================== -->
	<!--#region Lesser Margins -->

	<Thickness
		x:Key		="SmallMarginTLBR"
		ice:Freeze	="true"
		Left		="{StaticResource MarginSmall}"
		Top			="{StaticResource MarginSmall}"
		Right		="{StaticResource MarginSmall}"
		Bottom		="{StaticResource MarginSmall}" />

	<Thickness
		x:Key		="SmallMarginTLR"
		ice:Freeze	="true"
		Left		="{StaticResource MarginSmall}"
		Top			="{StaticResource MarginSmall}"
		Right		="{StaticResource MarginSmall}"
		Bottom		="0" />

	<Thickness
		x:Key		="SmallMarginBR"
		ice:Freeze	="true"
		Left		="0"
		Top			="0"
		Right		="{StaticResource MarginSmall}"
		Bottom		="{StaticResource MarginSmall}" />

	<Thickness
		x:Key		="SmallMarginTL"
		ice:Freeze	="true"
		Left		="{StaticResource MarginSmall}"
		Top			="{StaticResource MarginSmall}"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="SmallMarginLR"
		ice:Freeze	="true"
		Left		="{StaticResource MarginSmall}"
		Top			="0"
		Right		="{StaticResource MarginSmall}"
		Bottom		="0" />

	<Thickness
		x:Key		="SmallMarginL"
		ice:Freeze	="true"
		Left		="{StaticResource MarginSmall}"
		Top			="0"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="SmallMarginR"
		ice:Freeze	="true"
		Left		="0"
		Top			="0"
		Right		="{StaticResource MarginSmall}"
		Bottom		="0" />

	<Thickness
		x:Key		="SmallMarginT"
		ice:Freeze	="true"
		Left		="0"
		Top			="{StaticResource MarginSmall}"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="SmallMarginB"
		ice:Freeze	="true"
		Left		="0"
		Top			="0"
		Right		="0"
		Bottom		="{StaticResource MarginSmall}" />

	<!--#endregion Lesser Margins -->

	<!-- === Small ================================================================================================ -->
	<!--#region Small Margins -->

	<Thickness
		x:Key		="TinyMarginTLBR"
		ice:Freeze	="true"
		Left		="{StaticResource MarginTiny}"
		Top			="{StaticResource MarginTiny}"
		Right		="{StaticResource MarginTiny}"
		Bottom		="{StaticResource MarginTiny}" />

	<Thickness
		x:Key		="TinyMarginL"
		ice:Freeze	="true"
		Left		="{StaticResource MarginTiny}"
		Top			="0"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="TinyMarginT"
		ice:Freeze	="true"
		Left		="0"
		Top			="{StaticResource MarginTiny}"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="TinyMarginB"
		ice:Freeze	="true"
		Left		="0"
		Top			="0"
		Right		="0"
		Bottom		="{StaticResource MarginTiny}" />

	<Thickness
		x:Key		="TinyMarginTL"
		ice:Freeze	="true"
		Left		="{StaticResource MarginTiny}"
		Top			="{StaticResource MarginTiny}"
		Right		="0"
		Bottom		="0" />

	<Thickness
		x:Key		="TinyMarginBR"
		ice:Freeze	="true"
		Left		="0"
		Top			="0"
		Right		="{StaticResource MarginTiny}"
		Bottom		="{StaticResource MarginTiny}" />

</ResourceDictionary>